%html.no-js
  <!--<![endif]-->
  %head
    %meta{ :charset => "utf-8" }
    %meta{ "http-equiv" => "X-UA-Compatible", :content => "IE=edge,chrome=1" }
    %title Pick My Fruit
    %meta{ :name => "description", :content => "Pick My Fruit helps homeowners share the fruit on their trees that would otherwise go to waste" }
    %meta{ :name => "author", :content => "James A. Rosen" }
    %meta{ :name => "viewport", :content => "width=device-width, initial-scale=1.0" }
    = stylesheet_link_tag 'screen', :media => 'screen, projection'
    %script{ :src => "/javascripts/modernizr-1.6.min.js" }

  %body
    #container
      %header.page
        %hgroup
          %h1 Pick My Fruit
          %h2 Don't let your fruit go to waste
      #main
        = yield
      %footer.page
        Site by
        %a{ :href => 'http://jamesarosen.com/', :rel => 'author' } James A. Rosen
        |
        Domain courtesy of
        %a{ :href => "http://jaketrimble.com/" } Jake Trimble
    %script{ :src => "//ajax.googleapis.com/ajax/libs/jquery/1.5/jquery.js" }
    %script !window.jQuery && document.write(unescape('%3Cscript src="/javascripts/vendor/jquery-1.5.js"%3E%3C/script%3E'))
    /[if lt IE 7 ]
      %script{ :src => "js/dd_belatedpng.js" }
      :javascript
        DD_belatedPNG.fix('img, .png_bg');
    :javascript
      var _gaq = [['_setAccount', 'UA-22183079-1'], ['_trackPageview']];
      (function(d, t) {
        var g = d.createElement(t),
            s = d.getElementsByTagName(t)[0];

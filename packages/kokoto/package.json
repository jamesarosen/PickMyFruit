{
	"name": "@pickmyfruit/kokoto",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"description": "DBOS-inspired durable workflow runtime for SQLite — workflows, steps, queues, crash recovery.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./runtime.server": {
			"types": "./src/runtime.server.ts",
			"default": "./src/runtime.server.ts"
		},
		"./schema.server": {
			"types": "./src/schema.server.ts",
			"default": "./src/schema.server.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"clean": "rm -rf dist",
		"format": "pnpm run format:write",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint": "oxlint",
		"lint:ci": "oxlint --format github",
		"lint:fix": "oxlint --fix",
		"test": "pnpm run test:watch",
		"test:run": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=github-actions",
		"test:watch": "vitest",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"peerDependencies": {
		"@libsql/client": "*"
	},
	"devDependencies": {
		"@libsql/client": "0.17.3",
		"@types/node": "25.6.0",
		"oxlint": "^1.62.0",
		"prettier": "3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}

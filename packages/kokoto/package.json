{
	"name": "@pickmyfruit/kokoto",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"description": "Durable compute workflows on SQLite for Node",
	"exports": {
		".": "./src/index.server.ts",
		"./runtime.server": "./src/runtime.server.ts"
	},
	"scripts": {
		"format": "pnpm run format:write",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint": "oxlint",
		"lint:ci": "oxlint --format github",
		"lint:fix": "oxlint --fix",
		"test": "pnpm run test:watch",
		"test:run": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=github-actions",
		"test:watch": "vitest",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
	},
	"dependencies": {
		"@libsql/client": "0.17.3"
	},
	"peerDependencies": {
		"@sentry/node": "^10.51.0",
		"pino": "^10.3.1"
	},
	"peerDependenciesMeta": {
		"@sentry/node": {
			"optional": true
		},
		"pino": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sentry/node": "^10.51.0",
		"@types/node": "25.6.0",
		"oxlint": "^1.62.0",
		"pino": "^10.3.1",
		"prettier": "3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}

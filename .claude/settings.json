{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_input.file_path' | { read file_path; ${CLAUDE_PROJECT_DIR}/bin/after-write.sh \"$file_path\"; }"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PROJECT_DIR}/bin/after-turn.sh"
					}
				]
			}
		]
	},
	"permissions": {
		"allow": ["Bash(./bin/*)", "Bash(bin/*)", "mcp__context7__query-docs"]
	}
}

{
	"name": "@pickmyfruit/www",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"description": "www.pickmyfruit.com Application",
	"scripts": {
		"build": "vite build",
		"dev": "PORT=${PORT:-5173} vite dev",
		"start": "node .output/server/index.mjs",
		"format": "pnpm run format:write",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint:fix": "oxlint --fix",
		"lint": "oxlint",
		"lint:ci": "oxlint --format github",
		"preview": "vite preview",
		"test": "pnpm run test:watch",
		"test:run": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=github-actions",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf .output dist .nitro .test-dbs && git checkout HEAD -- src/routeTree.gen.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:seed": "vite-node src/data/seed.server.ts",
		"db:backfill-public-h3": "vite-node src/data/backfill-public-h3.server.ts",
		"deploy": "fly deploy",
		"deploy:setup": "fly launch --no-deploy",
		"logs": "fly logs",
		"ssh": "fly ssh console"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1042.0",
		"@aws-sdk/lib-storage": "3.1042.0",
		"@kobalte/core": "^0.13.11",
		"@libsql/client": "0.17.3",
		"@pickmyfruit/kokoto": "workspace:*",
		"@sentry/solid": "^10.55.0",
		"@sentry/solidstart": "^10.55.0",
		"@tanstack/solid-router": "^1.170.8",
		"@tanstack/solid-start": "^1.168.14",
		"better-auth": "^1.6.11",
		"clsx": "^2.1.1",
		"drizzle-orm": "0.45.2",
		"h3-js": "^4.4.0",
		"is-network-error": "^1.3.2",
		"lucide-solid": "^1.17.0",
		"maplibre-gl": "5.24.0",
		"mime-bytes": "^0.12.0",
		"pino": "^10.3.1",
		"resend": "^6.12.4",
		"sharp": "^0.34.5",
		"solid-js": "1.9.13",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@faker-js/faker": "10.4.0",
		"@playwright/test": "^1.60.0",
		"@solidjs/testing-library": "^0.8.10",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "25.9.1",
		"content-security-policy-parser": "^0.6.0",
		"drizzle-kit": "0.31.10",
		"exiftool-vendored": "35.21.0",
		"exiftool-vendored.pl": "13.59.0",
		"jsdom": "^29.1.1",
		"nitro": "3.0.260429-beta",
		"oxlint": "^1.67.0",
		"pino-pretty": "^13.1.3",
		"prettier": "3.8.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vite-node": "^6.0.0",
		"vite-plugin-solid": "2.11.12",
		"vitest": "^4.1.7"
	}
}

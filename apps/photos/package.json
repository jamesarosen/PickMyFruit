{
	"name": "@pmf/photos",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"description": "Pick My Fruit — photo transform service",
	"scripts": {
		"build": "tsc",
		"dev": "node --watch dist/index.js",
		"start": "node dist/index.js",
		"format": "pnpm run format:write",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"lint:ci": "oxlint --format github",
		"test": "pnpm run test:watch",
		"test:run": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=github-actions",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.4",
		"hono": "^4.8.4",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@types/node": "^25.2.3",
		"oxlint": "^1.47.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}

{
	"name": "@pickmyfruit/resend-sync",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"description": "Long-running cursor worker that syncs PickMyFruit users to Resend Audiences",
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"clean": "rm -rf dist",
		"dev": "tsx watch --env-file=.env.development src/main.ts",
		"start": "node dist/main.js",
		"format": "pnpm run format:write",
		"format:check": "prettier --check .",
		"format:write": "prettier --write .",
		"lint": "oxlint",
		"lint:ci": "oxlint --format github",
		"lint:fix": "oxlint --fix",
		"test": "pnpm run test:watch",
		"test:run": "vitest run",
		"test:ci": "vitest run --reporter=default --reporter=github-actions",
		"test:watch": "vitest",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@sentry/node": "^10.51.0",
		"pino": "^10.3.1",
		"undici": "^7.16.0",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@types/node": "25.6.0",
		"oxlint": "^1.62.0",
		"pino-pretty": "^13.1.3",
		"prettier": "3.8.3",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
